APP_ENV=dev
DATABASE_URL=postgresql+psycopg://lpk:lpk@localhost:5432/lpk
# 発音評価プロバイダ: stub | azure (stub needs no credentials)
PROVIDER_MODE=stub
# 会話・面接のLLM: stub | bedrock（bedrock は AWS 資格情報を boto3 既定チェーンで解決）
LLM_PROVIDER_MODE=stub
AWS_REGION=ap-northeast-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
# provider_mode=azure のとき必須（Azure AI Speech, ja-JP Pronunciation Assessment）
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=japaneast
# カスタムサブドメインを使う場合のみ（例: https://myresource.cognitiveservices.azure.com）
AZURE_SPEECH_ENDPOINT=
