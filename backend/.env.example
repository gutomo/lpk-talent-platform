APP_ENV=dev
DATABASE_URL=postgresql+psycopg://lpk:lpk@localhost:5432/lpk
# AI provider mode: stub | azure | bedrock (stub needs no credentials)
PROVIDER_MODE=stub
# provider_mode=azure のとき必須（Azure AI Speech, ja-JP Pronunciation Assessment）
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=japaneast
# カスタムサブドメインを使う場合のみ（例: https://myresource.cognitiveservices.azure.com）
AZURE_SPEECH_ENDPOINT=
